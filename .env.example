# PromptRouter Environment Variables
# Copy to .env and fill in your keys

# Provider API Keys
ANTHROPIC_API_KEY=sk-ant-...
DEEPSEEK_API_KEY=sk-...
OPENAI_API_KEY=sk-...   # optional

# Server Config
PORT=3000

# Admin dashboard secret
ADMIN_SECRET=change-me-in-production

# Router mode: bring_your_own | hosted | hybrid
#   bring_your_own — all users provide their own API keys (free tier)
#   hosted — users use your shared provider pool (paid tier)
#   hybrid — free users bring keys, paid users use your pool
ROUTER_MODE=hybrid

# Key encryption key (32 bytes as 64-char hex). Auto-generated if unset.
# Set this to a fixed value in production so keys survive restarts.
# KEY_ENCRYPTION_KEY=

# Optional: Redis cache (leave empty for in-memory)
# REDIS_URL=redis://localhost:6379

# Optional: Postgres for usage logging (leave empty for in-memory)
# DATABASE_URL=postgresql://user:pass@localhost:5432/promptrouter
